{
  "name": "@workspace/phonecraft-presentation",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "validate-slides": "node -e \"const m=require('./src/data/slides-manifest.json'); const positions=[...new Set(m.map(s=>s.position))]; if(positions.length!==m.length) throw new Error('Duplicate positions'); console.log('OK: '+m.length+' slides')\""
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "dependencies": {
    "react-router-dom": "^7.1.1"
  }
}
