{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export PORT=8080 NODE_ENV=development && pnpm run build && pnpm run start",
    "phonecraft:dev": "export PORT=8080 NODE_ENV=development && node phonecraft/index.js",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "catalog:",
    "express": "^4",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "pino": "^9",
    "pino-http": "^10",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
