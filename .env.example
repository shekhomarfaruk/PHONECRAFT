# ── Server ──────────────────────────────────────────────
PORT=4000
AUTH_SECRET=change_this_to_a_long_random_secret
ALLOWED_ORIGINS=https://phonecraft.tech,https://www.phonecraft.tech

# ── Admin Bootstrap ─────────────────────────────────────
ADMIN_IDENTIFIER=admin
ADMIN_PASSWORD=change_this_default_admin_password
MAIN_ADMIN_REFER_CODE=ADMIN01

# ── Telegram (Finance: deposit/withdraw/admin tx) ───────
# Fallback old vars are still supported, but these are preferred.
TELEGRAM_FINANCE_BOT_TOKEN=your_finance_bot_token_here
TELEGRAM_FINANCE_CHAT_IDS=-100xxxxxxxxxx

# ── Telegram (Live Support) ──────────────────────────────
# Multiple chat ids can be provided comma-separated.
TELEGRAM_SUPPORT_BOT_TOKEN=your_support_bot_token_here
TELEGRAM_SUPPORT_CHAT_IDS=5667850636,6752004892,5973619782

# Legacy fallback (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Webhook URL (Azure production domain) ────────────────
WEBHOOK_URL=https://your-domain.com
