# ── Server ──────────────────────────────────────────────
PORT=4000
AUTH_SECRET=change_this_to_a_long_random_secret
ALLOWED_ORIGINS=https://phonecraft.tech,https://www.phonecraft.tech

# ── Admin Bootstrap ─────────────────────────────────────
ADMIN_IDENTIFIER=admin
ADMIN_PASSWORD=change_this_default_admin_password
MAIN_ADMIN_REFER_CODE=ADMIN01

# ── Telegram Bot ─────────────────────────────────────────
# Step 1: Telegram-এ @BotFather-কে message করুন → /newbot
# Step 2: Bot-এর নাম ও username দিন → Token পাবেন
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Telegram Chat ID ─────────────────────────────────────
# আপনার Telegram Channel বা Group-এর Chat ID বসান
TELEGRAM_ADMIN_CHAT_ID=-100xxxxxxxxxx

# ── Webhook URL (ngrok or production domain) ─────────────
WEBHOOK_URL=https://your-domain.com
